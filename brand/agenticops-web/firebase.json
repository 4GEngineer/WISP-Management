{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "firebase.hosting-wisptools-agenticop.json",
      "**/.*",
      "**/node_modules/**",
      "AGENTS.md",
      "README.md",
      "DNS_SETUP.md",
      "DOMAIN_DECISION_CHECKLIST.md",
      "LINKEDIN_LAUNCH.md",
      "docs/**",
      "scripts/**",
      ".firebaserc.example"
    ],
    "errorDocument": "404.html",
    "headers": [
      {
        "source": "**/*.@(svg|ico|png|jpg|jpeg|gif|webp)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=86400"
          }
        ]
      },
      {
        "source": "**/*.@(html|json|xml|txt)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache, no-store, must-revalidate"
          }
        ]
      },
      {
        "source": "**/*.md",
        "headers": [
          {
            "key": "Content-Type",
            "value": "text/markdown; charset=utf-8"
          },
          {
            "key": "Cache-Control",
            "value": "no-cache, no-store, must-revalidate"
          }
        ]
      },
      {
        "source": "**/*.css",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=3600"
          }
        ]
      },
      {
        "source": "**/*.js",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=3600"
          }
        ]
      }
    ],
    "cleanUrls": false,
    "trailingSlash": false
  }
}
